# Ranhill SAJ monorepo — environment templates
#
# Backend:  copy backend/.env.example  → backend/.env
# Frontend: copy frontend/.env.example → frontend/.env.local
#
# Production (PM2): ports are set in ecosystem.config.js
#   Backend  → 4013
#   Frontend → 3017 (serves frontend/.next after `npm run build`)

# --- backend/.env ---
# PORT=4013
# MONGODB_URI=mongodb://127.0.0.1:27017/ranhill_saj
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_EXPIRES_IN=7d

# --- frontend/.env.local (dev) or frontend/.env.production (PM2) ---
# NEXT_PUBLIC_API_URL=http://localhost:4013/api
